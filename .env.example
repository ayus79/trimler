# Copy this file to .env and fill in real values for your machine.
# Nothing here is a real secret - these are placeholder examples.

APP_NAME=Trimler
APP_VERSION=0.1.0
APP_ENV=local

# HTTP Basic Auth for /docs, /redoc, /openapi.json.
API_DOCS_USERNAME=admin
API_DOCS_PASSWORD=change-this-to-a-strong-password
# Comma-separated. IPs/hosts in this list bypass the Basic Auth prompt.
API_DOCS_ALLOWED_IPS="127.0.0.1,localhost"

# Postgres. Note: DATABASE_URL is its own setting, not derived from
# DATABASE_NAME at runtime - if you change DATABASE_NAME, update the
# database name inside DATABASE_URL too.
DATABASE_NAME=trimler
DATABASE_URL=postgresql://postgres@localhost:5432/trimler

# Redis (cache-aside layer, click counters, rate limiter).
REDIS_URL=redis://localhost:6379/0
